# Copy this file to .env for local development (never commit .env)
# On Railway, set these as environment variables in the dashboard.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key (for CV analysis)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Admin account email — this user gets the 'admin' role on first registration
ADMIN_EMAIL=eran.ganot@gmail.com

# Shared secret between Railway app and your Mac relay.py
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SYNC_API_KEY=your-random-secret-here

# ── Railway-managed (set automatically, do not override) ──────────────────────

# Railway injects $PORT automatically; app.py reads it via _cfg("PORT", ...)
# PORT=8080

# ── Storage paths (set these in Railway after attaching a persistent volume) ──

# Absolute path to the directory where jobs.db should live on the volume
# DATABASE_PATH=/data/jobs.db

# Absolute path to the directory where uploaded CVs should be stored
# UPLOADS_DIR=/data/uploads

# ══════════════════════════════════════════════════════════════════════════════
# INGESTION PIPELINE (ingestion/) — multi-source sourcing
# FREE sources (Big-Tech endpoints) run for everyone. PAID sources below run for
# the ADMIN user only. Leave any key blank to skip that source gracefully.
# ══════════════════════════════════════════════════════════════════════════════

# -- Retain threshold (jobs scoring below this %% are dropped) --
INGEST_SCORE_THRESHOLD=30

# -- Rotating residential proxies (used on ADMIN runs for heavy scraping) --
# Option A: Bright-Data / Oxylabs style credentials (sticky sessions auto-added)
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_HOST=brd.superproxy.io
PROXY_PORT=22225
# Option B: a single gateway URL  →  RESIDENTIAL_PROXY_URL=http://user:pass@host:port
RESIDENTIAL_PROXY_URL=
# Option C: a comma-separated pool of proxy URLs
PROXY_POOL=
PROXY_ENABLED=1
PROXY_STICKY_SESSIONS=1

# -- Aggregators (PAID — admin only) --
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb
THEIRSTACK_API_KEY=
CORESIGNAL_API_KEY=

# -- Managed scraping (PAID — admin only) --
APIFY_TOKEN=
# comma-separated Apify actor ids for localized Israeli boards (user~actor)
APIFY_ACTORS=
JOBSPY_SITES=linkedin,indeed,glassdoor
JOBSPY_ENABLED=1

# -- Big Tech (FREE) --
BIGTECH_ENABLED=1
# Meta's careers GraphQL persisted-query id rotates; paste a current one to enable Meta
META_GRAPHQL_DOC_ID=
