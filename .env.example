# Copy this file to .env for local development (never commit .env)
# On Railway, set these as environment variables in the dashboard.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key (for CV analysis)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Admin account email — this user gets the 'admin' role on first registration
ADMIN_EMAIL=eran.ganot@gmail.com

# Shared secret between Railway app and your Mac relay.py
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SYNC_API_KEY=your-random-secret-here

# ── Railway-managed (set automatically, do not override) ──────────────────────

# Railway injects $PORT automatically; app.py reads it via _cfg("PORT", ...)
# PORT=8080

# ── Storage paths (set these in Railway after attaching a persistent volume) ──

# Absolute path to the directory where jobs.db should live on the volume
# DATABASE_PATH=/data/jobs.db

# Absolute path to the directory where uploaded CVs should be stored
# UPLOADS_DIR=/data/uploads
